#!/bin/bash
# Git post-commit hook that re-indexes the tracedecay after each commit.
#
# Install globally:
#   git config --global core.hooksPath ~/.git-hooks
#   cp scripts/post-commit ~/.git-hooks/post-commit
#   chmod +x ~/.git-hooks/post-commit
#
# Install per-repo:
#   cp scripts/post-commit .git/hooks/post-commit
#   chmod +x .git/hooks/post-commit

if command -v tracedecay &>/dev/null && [ -d ".tracedecay" ]; then
    tracedecay sync &>/dev/null &
fi
